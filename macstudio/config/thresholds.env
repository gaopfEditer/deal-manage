# 阈值配置（可被 mac_report.sh / mac_analyze.sh source）
# CPU 负载上限 = 逻辑核数 × 该系数（mac_report 会读 sysctl hw.logicalcpu）

SSD_PCT_WARN=80
SSD_PCT_CRITICAL=100
SSD_SPARE_CRITICAL=99
SSD_ERR_CRITICAL=0
SSD_TEMP_WARN=75
SSD_TEMP_CRITICAL=90

MEM_PRESSURE_WARN=65
MEM_PRESSURE_CRITICAL=80

SWAP_GB_WARN=5
SWAP_GB_CRITICAL=16

CPU_LOAD_FACTOR=0.7

# 日志路径（install 后默认 ~/Library/Logs/macstudio/metrics.csv）
# MACSTUDIO_LOG_DIR=/var/log/macstudio
